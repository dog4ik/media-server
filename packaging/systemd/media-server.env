# Environment overrides for the media-server systemd service.
# Uncomment and set values as needed, then run: systemctl restart media-server
#
# This file is a configuration file; your edits are preserved across upgrades.

# Log filter
#RUST_LOG=media_server=info

# Metadata provider API tokens.
#TMDB_TOKEN=
#TVDB_TOKEN=

# Provod proxy agent.
PROVOD_URL=https://agent.provod.rs
PROVOD_TOKEN=Bearer auth_token
